  "keyFeatures": [
    "Unified Microsoft Graph API access for Office 365, Azure AD, and Microsoft services",
    "Built with Kiota code generation for modern .NET experience",
    "Fluent request builder pattern mirroring REST API structure",
    "Support for .NET Standard 2.0, 2.1, and .NET 5+",
    "Integrated with Azure.Identity for authentication using TokenCredential",
    "Comprehensive resource models generated from Microsoft Graph metadata",
    "Built-in support for query parameters, collections, paging, and error handling",
    "Bi-weekly updates synchronized with Microsoft Graph API changes"
  ],
  "publicApiSurface": [
    "GraphServiceClient - Main client for Microsoft Graph API",
    "Me - Access current user's resources",
    "Users - User management and directory operations",
    "Groups - Group management and membership",
    "Applications - Application registration and management",
    "Drive/Drives - OneDrive and SharePoint file operations",
    "Messages - Email operations",
    "Calendar/Events - Calendar and event management",
    "Teams/Channels - Microsoft Teams integration",
    "Sites - SharePoint sites access",
    "DirectoryObjects - Azure AD directory objects",
    "ServicePrincipals - Service principal management",
    "Subscriptions - Change notification webhooks",
    "Batch requests - Batch multiple API calls",
    "IAuthenticationProvider - Custom authentication implementation",
    "TokenCredential - Azure.Identity integration",
    "RequestInformation - Low-level request configuration",
    "QueryParameters - OData query options (Select, Filter, Expand, OrderBy, Top, Skip)"
  ]
}
